{
  "title": "SmartStock — Order Processing",
  "uid": "smartstock-orders",
  "description": "Purchase Order and Sales Order service traffic, Kafka event flows, and order lifecycle metrics.",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "tags": ["smartstock", "orders"],
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "annotations": { "list": [] },
  "links": [],
  "templating": {
    "list": [
      {
        "name": "order_service",
        "label": "Order Service",
        "type": "custom",
        "query": "purchase-order-service,sales-order-service",
        "multi": true,
        "includeAll": true,
        "allValue": "purchase-order-service|sales-order-service",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Service Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Service Status",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\"purchase-order-service|sales-order-service\"}",
          "instant": true,
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN" },
                "1": { "text": "UP" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Purchase Order Req/s",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"purchase-order-service\"}[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sales Order Req/s",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"sales-order-service\"}[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Combined Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_server_requests_seconds_count{job=~\"purchase-order-service|sales-order-service\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=~\"purchase-order-service|sales-order-service\"}[5m]))",
          "legendFormat": "5xx %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "HTTP Traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Rate — Purchase vs Sales Order",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$order_service\"}[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Response Latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=~\"$order_service\"}[5m])) by (job, le))",
          "legendFormat": "{{job}} p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\"$order_service\"}[5m])) by (job, le))",
          "legendFormat": "{{job}} p99"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "HTTP Status Distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$order_service\"}[5m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$order_service\"}[5m])) by (job, method, uri)",
          "legendFormat": "{{job}} {{method}} {{uri}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Kafka — Order Events",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Kafka Records Produced by Order Services",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kafka_producer_record_send_total{job=~\"$order_service\"}[5m])) by (job, topic)",
          "legendFormat": "{{job}} → {{topic}}"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "kafka_consumer_fetch_manager_records_lag_max{job=~\"$order_service\"}",
          "legendFormat": "{{job}} — {{topic}}"
        }
      ],
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 1000, "color": "red" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Outbox & Concurrency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Outbox Queue Depth (Order Services)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "smartstock_outbox_queue_depth{job=~\"$order_service\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Optimistic Lock Conflicts (409 responses)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$order_service\", status=\"409\"}[5m])) by (job)",
          "legendFormat": "{{job}} 409/s"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Logs",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }
    },
    {
      "id": 41,
      "type": "logs",
      "title": "Order Service Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=~\"purchase-order-service|sales-order-service\"} | logfmt | line_format \"{{.message}}\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
