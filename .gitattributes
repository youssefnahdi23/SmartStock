# Ensure all files use LF line endings consistently
* text=auto

# Source code
*.java text eol=lf
*.kt text eol=lf
*.groovy text eol=lf
*.scala text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# XML/Config
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
pom.xml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.adoc text eol=lf

# SQL
*.sql text eol=lf

# Shell scripts
*.sh text eol=lf eol=lf
*.bash text eol=lf

# Git related
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.jar binary
*.class binary
*.o binary
*.so binary
*.exe binary
*.gif binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
*.sqlite binary

# Archive files
*.tar binary
*.tar.gz binary
*.rar binary
*.zip binary
