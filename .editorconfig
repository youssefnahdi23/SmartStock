# EditorConfig helps enforce consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java files
[*.{java,kt}]
indent_style = space
indent_size = 4
max_line_length = 120

# XML/POM files
[*.{xml,pom}]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# SQL files
[*.sql]
indent_style = space
indent_size = 2

# Properties files
[*.{properties,gradle}]
indent_style = space
indent_size = 2

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf

# Makefile (must use tabs)
[Makefile]
indent_style = tab

# FXML (JavaFX)
[*.fxml]
indent_style = space
indent_size = 2

# CSS
[*.css]
indent_style = space
indent_size = 2
