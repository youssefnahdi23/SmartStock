# SmartStock Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Database ====================
# PostgreSQL credentials (used by all microservices)
DB_PASSWORD=smartstock123
DB_USER=smartstock

# ==================== Redis ====================
# Redis caching & session store (ADR-0011)
REDIS_PASSWORD=smartstock123

# ==================== MinIO ====================
# S3-compatible object storage for data export
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET=smartstock-data

# ==================== Security ====================
# JWT Configuration (ADR-0005)
# Generate a strong secret: openssl rand -base64 256
JWT_SECRET=<JWT_SECRET>
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=2592000000

# ==================== Application ====================
APP_NAME=SmartStock
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# ==================== Kafka ====================
# Event streaming (ADR-0004)
KAFKA_BROKER=kafka:9092
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# ==================== Observability ====================
# Logging & Monitoring (ADR-0009)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# ==================== API Gateway ====================
# API Gateway configuration (ADR-0008)
API_GATEWAY_PORT=8080
API_GATEWAY_TIMEOUT_MS=30000

# ==================== Services ====================
# Canonical port allocation: 800x (matches application.yml SERVER_PORT defaults,
# service Dockerfiles, docker-compose, and infrastructure/prometheus.yml).
# The API Gateway listens on 8080.

# Identity Service
IDENTITY_SERVICE_PORT=8001
IDENTITY_SERVICE_DB=smartstock_identity

# Product Service
PRODUCT_SERVICE_PORT=8002
PRODUCT_SERVICE_DB=smartstock_product

# Inventory Service
INVENTORY_SERVICE_PORT=8003
INVENTORY_SERVICE_DB=smartstock_inventory

# Warehouse Service
WAREHOUSE_SERVICE_PORT=8004
WAREHOUSE_SERVICE_DB=smartstock_warehouse

# Supplier Service
SUPPLIER_SERVICE_PORT=8005
SUPPLIER_SERVICE_DB=smartstock_supplier

# Customer Service
CUSTOMER_SERVICE_PORT=8006
CUSTOMER_SERVICE_DB=smartstock_customer

# Purchase Order Service
PURCHASE_ORDER_SERVICE_PORT=8007
PURCHASE_ORDER_SERVICE_DB=smartstock_purchase_order

# Sales Order Service
SALES_ORDER_SERVICE_PORT=8008
SALES_ORDER_SERVICE_DB=smartstock_sales_order

# Audit Service (skeleton)
AUDIT_SERVICE_PORT=8009
AUDIT_SERVICE_DB=smartstock_audit

# Notification Service (skeleton)
NOTIFICATION_SERVICE_PORT=8010
NOTIFICATION_SERVICE_DB=smartstock_notification

# Reporting Service (skeleton)
REPORTING_SERVICE_PORT=8011
REPORTING_SERVICE_DB=smartstock_reporting

# Analytics Service (skeleton)
ANALYTICS_SERVICE_PORT=8012
ANALYTICS_SERVICE_DB=smartstock_analytics

# Data Export Service (skeleton)
DATA_EXPORT_SERVICE_PORT=8013
DATA_EXPORT_SERVICE_DB=smartstock_data_export

# Order Service (legacy skeleton, superseded by purchase/sales-order)
ORDER_SERVICE_PORT=8014
ORDER_SERVICE_DB=smartstock_order

# ==================== Email (Notifications) ====================
# Email provider (e.g., Brevo)
MAIL_SMTP_HOST=smtp.brevo.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=your-email@example.com
MAIL_SMTP_PASSWORD=your-api-key
MAIL_FROM=noreply@smartstock.dev

# ==================== Development ====================
# For development only - should NEVER be true in production
DEBUG_MODE=false
ALLOW_CORS_LOCALHOST=true
SKIP_AUTH_FOR_TESTING=false

# ==================== Observability ====================
# Monitoring (Prometheus)
PROMETHEUS_RETENTION_DAYS=7
PROMETHEUS_SCRAPE_INTERVAL=15s

# Logging (Loki)
LOKI_RETENTION_DAYS=7

# Tracing (Tempo)
TEMPO_RETENTION_HOURS=168

# General
LOG_LEVEL=INFO
TZ=UTC

# ==================== Administration ====================
# pgAdmin - PostgreSQL UI
PGADMIN_EMAIL=admin@smartstock.dev
PGADMIN_PASSWORD=admin123

# Grafana - Dashboards & Visualization
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ==================== RabbitMQ ====================
# Message Broker (Alternative to Kafka)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==================== Deployment ====================
# Docker/Kubernetes
DOCKER_REGISTRY=docker.io
K8S_NAMESPACE=smartstock
K8S_REPLICAS=3
K8S_MAX_REPLICAS=10
